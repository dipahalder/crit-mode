# Copy to .env and fill in. The Express critique proxy (server/) reads this.
# The app works fully on static data with no key set; the LLM is additive.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-6. Set claude-opus-4-8 for higher
# quality, slower critiques.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional. Port for the critique proxy (Vite proxies /critique here).
# PORT=8787
